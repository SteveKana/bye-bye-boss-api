from __future__ import annotations

import uuid

from fastapi import APIRouter, status

from app.core.dependencies import DBSession, Pagination
from app.core.pagination import Page
from app.modules.auth import CurrentUser
from app.modules.{{PLURAL}}.schemas import {{CLASS}}Create, {{CLASS}}Read, {{CLASS}}Update
from app.modules.{{PLURAL}}.service import {{CLASS}}Service

router = APIRouter(prefix="/{{PLURAL}}", tags=["{{PLURAL}}"])


@router.post("", response_model={{CLASS}}Read, status_code=status.HTTP_201_CREATED)
async def create_{{VAR}}(
    data: {{CLASS}}Create, _: CurrentUser, session: DBSession
) -> {{CLASS}}Read:
    obj = await {{CLASS}}Service(session).create(data)
    return {{CLASS}}Read.model_validate(obj)


@router.get("", response_model=Page[{{CLASS}}Read])
async def list_{{PLURAL}}(
    _: CurrentUser, session: DBSession, params: Pagination
) -> Page[{{CLASS}}Read]:
    page = await {{CLASS}}Service(session).list(params)
    return Page[{{CLASS}}Read].create(
        [{{CLASS}}Read.model_validate(o) for o in page.items], page.total, params
    )


@router.get("/{id}", response_model={{CLASS}}Read)
async def get_{{VAR}}(
    id: uuid.UUID, _: CurrentUser, session: DBSession
) -> {{CLASS}}Read:
    obj = await {{CLASS}}Service(session).get(id)
    return {{CLASS}}Read.model_validate(obj)


@router.patch("/{id}", response_model={{CLASS}}Read)
async def update_{{VAR}}(
    id: uuid.UUID, data: {{CLASS}}Update, _: CurrentUser, session: DBSession
) -> {{CLASS}}Read:
    obj = await {{CLASS}}Service(session).update(id, data)
    return {{CLASS}}Read.model_validate(obj)


@router.delete("/{id}", status_code=status.HTTP_204_NO_CONTENT)
async def delete_{{VAR}}(
    id: uuid.UUID, _: CurrentUser, session: DBSession
) -> None:
    await {{CLASS}}Service(session).delete(id)

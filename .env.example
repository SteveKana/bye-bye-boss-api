# ---- App ----------------------------------------------------------------
APP_NAME=byebyeboss
APP_ENV=local
DEBUG=true
API_VERSION=v1

# ---- Database -----------------------------------------------------------
# Quick start (no infra needed):
DATABASE_URL=sqlite+aiosqlite:///./app.db
# Postgres (docker-compose):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/app
DATABASE_ECHO=false
DATABASE_AUTO_CREATE=true

# ---- Security / JWT -----------------------------------------------------
SECRET_KEY=change-me-in-production-please-32chars-min
JWT_ALGORITHM=HS256
# JWT_ISSUER=my-service
# JWT_AUDIENCE=my-clients
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_MINUTES=10080

# Bootstrap admin (seeded at startup if not present)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# ---- CORS ---------------------------------------------------------------
# CORS_ALLOW_ORIGINS=["http://localhost:3000"]

# ---- Cache (optional; falls back to in-memory) --------------------------
# REDIS_URL=redis://localhost:6379/0
CACHE_DEFAULT_TTL_SECONDS=60

# ---- Rate limiting (uses Redis when REDIS_URL is set, else in-memory) ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_TIMES=100
RATE_LIMIT_DEFAULT_SECONDS=60

# ---- Scheduler ----------------------------------------------------------
# Also drives the mail queue worker below.
SCHEDULER_ENABLED=true

# ---- Mail ---------------------------------------------------------------
# Outgoing mail is queued in the DB and flushed by a scheduled worker.
# MAIL_PROVIDER picks the transport: smtp | mailgun.
# If the selected provider is not configured, messages are only logged.
MAIL_PROVIDER=smtp

# -- Mailgun (MAIL_PROVIDER=mailgun) --------------------------------------
# MAILGUN_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxx-xxxxxxxx
# MAILGUN_DOMAIN=mg.example.fr
# Host or full URL. EU accounts: api.eu.mailgun.net
# MAILGUN_ENDPOINT=api.eu.mailgun.net
MAILGUN_TIMEOUT_SECONDS=15

# -- SMTP (MAIL_PROVIDER=smtp) --------------------------------------------
# Local dev with MailHog (smtp 1025, web UI http://localhost:8025):
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=false
#
# Production (OVH example):
# SMTP_HOST=ssl0.ovh.net
# SMTP_PORT=587
# SMTP_USER=contact@byebyeboss.fr
# SMTP_PASSWORD=change-me
# SMTP_STARTTLS=true
SMTP_TIMEOUT_SECONDS=15

EMAIL_FROM=contact@byebyeboss.fr
EMAIL_FROM_NAME=Bye Bye Boss

# Queue worker: how often it runs, how many mails per pass, retries before
# a message is marked failed.
MAIL_QUEUE_INTERVAL_MINUTES=1
MAIL_QUEUE_BATCH_SIZE=20
MAIL_MAX_ATTEMPTS=5

# ---- Logging ------------------------------------------------------------
LOG_LEVEL=INFO
LOG_JSON=false
